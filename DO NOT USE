function openTaskManager() {
  const win = createWindow('Task Manager', 860, 580);

  let snap = null;
  let lastTickAt = performance.now();
  let cpuVal = 8;
  let ramPctLive = performance.memory ? (performance.memory.usedJSHeapSize / performance.memory.jsHeapSizeLimit) * 100 : 25;
  const cpuHistory = Array(60).fill(cpuVal);
  const ramHistory = Array(60).fill(ramPctLive);
  const diskHistory = Array(60).fill(0);
  const netHistory  = Array(60).fill(0);
  let diskVal = 0, netVal = 0;

  buildTmSnapshot().then(s => {
    snap = s;
    const set = (id, t) => { const el = document.getElementById(id); if (el) el.textContent = t; };
    const c = Number(s.cores) || 4;
    set('tm-cpu-sub', c + ' Cores, ' + c + ' Logical Processors');
    const ramGb = s.dm != null ? String(s.dm) : '16';
    set('tm-ram-sub', ramGb + ' GB DDR5 · 5600 MT/s');
    if (s.storageQuota > 0) diskVal = (s.storageUsage / s.storageQuota) * 100;
    set('tm-disk-sub', 'NVMe WD PC SN740 SSD');
    let nsub = 'Realtek PCIe GbE Family Controller';
    if (s.conn) {
      netVal = typeof s.conn.downlink === 'number' ? s.conn.downlink : 0;
      const et = String(s.conn.effectiveType || '').toLowerCase();
      if (et === 'wifi' || et === '4g' || et === '3g' || et === '2g') nsub = 'Intel(R) Wi-Fi 6E AX211 160MHz';
    }
    set('tm-net-sub', nsub);
  });

  function step() {
    const now = performance.now();
    const interval = 800;
    const drift = Math.max(0, now - lastTickAt - interval);
    lastTickAt = now;
    const fromLag = Math.min(100, drift * 1.1);
    cpuVal = Math.min(100, Math.max(0, cpuVal * 0.82 + fromLag * 0.18 + (Math.random() - 0.5) * 2));
    cpuHistory.push(+cpuVal.toFixed(1)); cpuHistory.shift();

    if (performance.memory) {
      ramPctLive = (performance.memory.usedJSHeapSize / performance.memory.jsHeapSizeLimit) * 100;
    } else {
      ramPctLive = Math.min(100, Math.max(5, ramPctLive + (Math.random() - 0.5) * 3));
    }
    ramHistory.push(+ramPctLive.toFixed(1)); ramHistory.shift();

    if (snap && snap.storageQuota > 0) {
      diskVal = (snap.storageUsage / snap.storageQuota) * 100;
    } else {
      diskVal += (Math.random() - 0.5) * 2;
      diskVal = Math.max(0, Math.min(100, diskVal));
    }
    diskHistory.push(+diskVal.toFixed(1)); diskHistory.shift();

    if (snap && snap.conn && typeof snap.conn.downlink === 'number') {
      netVal = snap.conn.downlink;
