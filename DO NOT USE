<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Windows 11 Ultra OS Simulator</title>
<style>
:root{
  --task:rgba(255,255,255,0.08);
  --glass:rgba(255,255,255,0.12);
  --glass2:rgba(255,255,255,0.18);
  --accent:#00ff7f;
}
*{box-sizing:border-box;user-select:none}
body{
  margin:0;
  font-family:"Segoe UI",sans-serif;
  background:#888;
  overflow:hidden;
  color:white;
}
#desktop{position:absolute;inset:0;padding:20px}

/* TASKBAR */
#taskbar{
  position:absolute;bottom:0;width:100%;height:60px;
  background:var(--task);backdrop-filter:blur(20px);
  display:flex;align-items:center;justify-content:center;z-index:9999;
}
#taskIcons{display:flex;gap:8px;align-items:center}
.taskBtn{
  width:44px;height:44px;display:flex;align-items:center;justify-content:center;
  border-radius:10px;cursor:pointer;background:rgba(255,255,255,0.05);font-size:18px;
}
.taskBtn:hover{background:var(--glass2)}
.taskBtn{position:relative;}
.taskBtn:not(.taskBtn--start)::after{
  content:'';position:absolute;bottom:3px;left:50%;transform:translateX(-50%);
  width:6px;height:3px;border-radius:2px;
  background:rgba(255,255,255,0.35);
  transition:width .25s cubic-bezier(.34,1.56,.64,1), background .25s, box-shadow .25s;
}
.taskBtn.open::after{
  width:18px;
  background:var(--accent,#00d4ff);
  box-shadow:0 0 7px var(--accent,#00d4ff);
}

/* DESKTOP DEMO TEXT */
#desktopDemo{
  position:fixed;inset:0;bottom:60px;
  display:flex;align-items:center;justify-content:center;
  pointer-events:none;z-index:0;
}
#desktopDemoText{
  font-size:clamp(32px,6vw,72px);font-weight:700;color:rgba(0,0,0,0.45);
  letter-spacing:2px;font-family:"Segoe UI",sans-serif;text-align:center;
  user-select:none;
}

/* SETTINGS PANEL */
.settings-root{
  flex:1;overflow-y:auto;padding:28px 32px;
  background:#111;display:flex;flex-direction:column;gap:24px;
}
.settings-section{display:flex;flex-direction:column;gap:12px;}
.settings-label{font-size:11px;letter-spacing:1px;opacity:.45;text-transform:uppercase;}
.settings-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.bg-preset{
  width:64px;height:40px;border-radius:8px;cursor:pointer;border:2px solid transparent;
  transition:.15s;flex-shrink:0;
}
.bg-preset.selected,.bg-preset:hover{border-color:var(--accent,#00d4ff);}
.accent-swatch{
  width:32px;height:32px;border-radius:50%;cursor:pointer;border:2px solid transparent;
  transition:.15s;flex-shrink:0;
}
.accent-swatch.selected,.accent-swatch:hover{border-color:#fff;transform:scale(1.15);}
.settings-divider{border:none;border-top:1px solid rgba(255,255,255,0.07);margin:0;}
.custom-bg-row{display:flex;gap:8px;align-items:center;}
.custom-bg-input{
  flex:1;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);
  border-radius:8px;padding:8px 12px;color:#fff;font-size:12px;outline:none;
}
.custom-bg-input:focus{border-color:var(--accent,#00d4ff);}
.settings-apply-btn{
  padding:8px 16px;border-radius:8px;border:none;cursor:pointer;font-size:12px;
  background:var(--accent,#00d4ff);color:#000;font-weight:600;transition:.15s;
}
.settings-apply-btn:hover{opacity:.85;}

/* DEMO WATERMARK */
#demoWatermark{
  position:fixed;bottom:70px;right:16px;z-index:9998;
  background:rgba(90,90,90,0.72);backdrop-filter:blur(6px);
  color:rgba(255,255,255,0.85);font-size:11px;font-family:"Segoe UI",sans-serif;
  padding:4px 10px;border-radius:6px;letter-spacing:0.5px;
  pointer-events:none;border:1px solid rgba(255,255,255,0.12);
}

/* START MENU */
#start{
  position:absolute;bottom:80px;left:50%;
  transform:translateX(-50%) translateY(10px);
  width:560px;height:620px;
  background:rgba(18,18,18,0.55);backdrop-filter:blur(40px);
  border:1px solid rgba(255,255,255,0.08);border-radius:20px;
  padding:16px;display:flex;flex-direction:column;gap:12px;
  opacity:0;pointer-events:none;transition:.25s ease;z-index:99999;
}
#start.active{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0);}
.startSearch{
  width:100%;padding:11px 12px;border-radius:12px;border:none;outline:none;
  background:rgba(255,255,255,0.06);color:white;font-size:13px;
}
.startSectionTitle{font-size:11px;opacity:0.5;letter-spacing:1px;margin-top:4px;}
.pinnedGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;flex:1;}
.app{
  background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.06);
  border-radius:14px;padding:10px;font-size:12px;cursor:pointer;
  transition:.15s ease;display:flex;align-items:center;gap:8px;
}
.app:hover{background:rgba(255,255,255,0.12);transform:translateY(-2px);}
.startBottom{
  display:flex;justify-content:space-between;align-items:center;
  padding-top:10px;border-top:1px solid rgba(255,255,255,0.08);
}
.userBox,.powerBox{
  padding:7px 10px;border-radius:10px;background:rgba(255,255,255,0.06);font-size:12px;
}

/* WINDOW SYSTEM */
.window{
  position:absolute;width:900px;height:600px;background:#111;
  border-radius:12px;overflow:hidden;display:none;flex-direction:column;
  box-shadow:0 25px 70px rgba(0,0,0,0.6);
}
.window.fullscreen{
  left:0!important;top:0!important;width:100vw!important;
  height:calc(100vh - 60px)!important;border-radius:0;
}
.window.fullscreen .resizeHandle{display:none}
.titlebar{
  height:38px;background:#1f1f1f;display:flex;justify-content:space-between;
  align-items:center;padding:0 10px;cursor:grab;flex-shrink:0;
}
.controls span{margin-left:10px;cursor:pointer}
.controls span.win-fs{opacity:.85;font-size:14px;line-height:1}
iframe{flex:1;border:none;background:#000}
.resizeHandle{position:absolute;width:14px;height:14px;right:0;bottom:0;cursor:nwse-resize}

/* CONTEXT MENU */
#menu{
  position:absolute;display:none;background:#111;border:1px solid #333;
  border-radius:8px;min-width:180px;z-index:999999;
}
#menu div{padding:10px;cursor:pointer}
#menu div:hover{background:#222}

/* CMD */
.cmdBody{
  flex:1;background:#000;color:var(--accent);
  font-family:monospace;padding:10px;overflow:auto;
}
.cmdInput{
  width:100%;background:black;color:var(--accent);border:none;outline:none;
  font-family:monospace;padding:5px;flex-shrink:0;
}

/* ===== TASK MANAGER ===== */
.tm-root{
  flex:1;overflow:hidden;display:flex;flex-direction:column;
  background:#0d0d0d;font-family:"Segoe UI",sans-serif;
}
.tm-tabs{
  display:flex;gap:0;border-bottom:1px solid rgba(255,255,255,0.08);
  background:#141414;flex-shrink:0;
}
.tm-tab{
  padding:10px 20px;font-size:12px;cursor:pointer;color:rgba(255,255,255,0.5);
  border-bottom:2px solid transparent;transition:.15s;
}
.tm-tab.active{color:#fff;border-bottom-color:#00d4ff;}
.tm-tab:hover:not(.active){color:rgba(255,255,255,0.8);}
.tm-panel{display:none;flex:1;overflow:hidden;}
.tm-panel.active{display:flex;flex-direction:column;}

/* Performance panel */
.perf-layout{display:flex;flex:1;overflow:hidden;}
.perf-sidebar{
  width:200px;flex-shrink:0;border-right:1px solid rgba(255,255,255,0.06);
  overflow-y:auto;padding:8px 0;
}
.perf-sidebar-item{
  padding:10px 14px;cursor:pointer;transition:.12s;
  border-left:3px solid transparent;
}
.perf-sidebar-item.active{
  background:rgba(0,212,255,0.08);border-left-color:#00d4ff;
}
.perf-sidebar-item:hover:not(.active){background:rgba(255,255,255,0.04);}
.perf-sidebar-label{font-size:11px;color:rgba(255,255,255,0.5);margin-bottom:2px;}
.perf-sidebar-value{font-size:13px;font-weight:500;}
.perf-sidebar-mini{
  height:36px;border-radius:4px;overflow:hidden;margin-top:6px;
  background:rgba(255,255,255,0.04);position:relative;
}
.perf-content{flex:1;padding:20px;overflow-y:auto;display:flex;flex-direction:column;gap:16px;}
.perf-header{display:flex;justify-content:space-between;align-items:baseline;}
.perf-title{font-size:16px;font-weight:500;}
.perf-subtitle{font-size:12px;color:rgba(255,255,255,0.4);}
.perf-stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.perf-stat{background:rgba(255,255,255,0.04);border-radius:8px;padding:12px;}
.perf-stat-label{font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px;}
.perf-stat-val{font-size:18px;font-weight:500;}
.chart-wrap{background:rgba(255,255,255,0.03);border-radius:8px;padding:14px;position:relative;}
.chart-label{font-size:11px;color:rgba(255,255,255,0.4);margin-bottom:8px;display:flex;justify-content:space-between;}
canvas.sparkline{width:100%!important;display:block;}

/* Processes panel */
.proc-table{width:100%;border-collapse:collapse;font-size:12px;}
.proc-table th{
  background:#141414;padding:8px 12px;text-align:left;
  font-size:11px;color:rgba(255,255,255,0.4);font-weight:400;
  border-bottom:1px solid rgba(255,255,255,0.08);position:sticky;top:0;z-index:2;
  letter-spacing:.5px;text-transform:uppercase;cursor:pointer;
}
.proc-table th:hover{color:rgba(255,255,255,0.7);}
.proc-table td{padding:7px 12px;border-bottom:1px solid rgba(255,255,255,0.04);}
.proc-table tr:hover td{background:rgba(255,255,255,0.04);}
.proc-name{display:flex;align-items:center;gap:8px;}
.proc-icon{width:16px;height:16px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:11px;}
.bar-cell{width:100px;}
.mini-bar{height:4px;border-radius:2px;background:rgba(255,255,255,0.08);overflow:hidden;}
.mini-bar-fill{height:100%;border-radius:2px;transition:width .4s;}
.proc-scroll{flex:1;overflow-y:auto;}
.kill-btn{
  background:rgba(255,60,60,0.15);color:rgba(255,100,100,0.9);
  border:none;border-radius:4px;padding:3px 8px;font-size:11px;cursor:pointer;
}
.kill-btn:hover{background:rgba(255,60,60,0.3);}
</style>
</head>
<body>

<div id="desktop"></div>

<!-- START -->
<div id="start">
  <input class="startSearch" placeholder="Search apps, settings, documents..." />
  <div class="startSectionTitle">Pinned</div>
  <div class="pinnedGrid">
    <div class="app" onclick="openGame('https://irv77.github.io/hd_fnaf/1/')">&#x1F3AE; FNAF 1</div>
    <div class="app" onclick="openGame('https://irv77.github.io/hd_fnaf/2/')">&#x1F3AE; FNAF 2</div>
    <div class="app" onclick="openGame('https://irv77.github.io/hd_fnaf/3/')">&#x1F3AE; FNAF 3</div>
    <div class="app" onclick="openGame('https://irv77.github.io/hd_fnaf/4/')">&#x1F3AE; FNAF 4</div>
    <div class="app" onclick="openGame('https://freesh11.github.io/Games/EaglercraftX_1.8_WASM-GC_Offline_Download.html')">&#x26CF; Minecraft</div>
    <div class="app" onclick="openGame('https://freesh11.github.io/Games/fnae.html')">&#x1F3AD; FNAE</div>
    <div class="app" onclick="openTaskManager()">&#x1F4CA; Task Manager</div>
    <div class="app" onclick="openCMD()">&#x2328; CMD</div>
    <div class="app" onclick="openSettings()">&#x2699; Settings</div>
  </div>
  <div class="startBottom">
    <div class="userBox">&#x1F464; User</div>
    <div class="powerBox">&#x23FB;</div>
  </div>
</div>

<!-- DESKTOP DEMO TEXT -->
<div id="desktopDemo"><div id="desktopDemoText">demo 1.0934</div></div>

<!-- DEMO WATERMARK -->
<div id="demoWatermark">demo 1.0237</div>

<!-- TASKBAR -->
<div id="taskbar">
  <div id="taskIcons">
    <div class="taskBtn taskBtn--start" onclick="toggleStart()">&#x1FA9F;</div>
  </div>
</div>

<!-- CONTEXT MENU -->
<div id="menu">
  <div onclick="toggleStart()">Start</div>
  <div onclick="openTaskManager()">Task Manager</div>
  <div onclick="openCMD()">CMD</div>
  <div onclick="openSettings()">Settings</div>
</div>

<script>
let z = 10;
let windows = [];
let processes = [];
let procNextId = 1;

function allocProc(o) {
  return Object.assign({ id: procNextId++, win: null, name: 'App', mem: 100, cpu: 10 }, o);
}

/** Browser-exposed metrics (not full OS Task Manager). */
async function buildTmSnapshot() {
  const cores = navigator.hardwareConcurrency;
  const dm = navigator.deviceMemory;
  let usage = 0, quota = 0;
  try {
    if (navigator.storage && navigator.storage.estimate) {
      const e = await navigator.storage.estimate();
      usage = e.usage || 0;
      quota = e.quota || 0;
    }
  } catch (e) {}
  const mem = performance.memory;
  const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
  return {
    cores: cores || '—',
    dm,
    screen: screen.width + ' × ' + screen.height + ' @ ' + window.devicePixelRatio + 'x',
    lang: navigator.language,
    platform: navigator.platform || '—',
    mem,
    storageUsage: usage,
    storageQuota: quota,
    conn
  };
}

const start = document.getElementById('start');
const taskIcons = document.getElementById('taskIcons');

function toggleStart() { start.classList.toggle('active'); }
function bring(w) { w.style.zIndex = ++z; }

function createTask(win, icon) {
  const b = document.createElement('div');
  b.className = 'taskBtn open';
  b.innerText = icon;
  b.onclick = () => {
    if (win.style.display === 'none') {
      win.style.display = 'flex'; bring(win);
      b.classList.add('open');
    } else {
      win.style.display = 'none';
      b.classList.remove('open');
    }
  };
  taskIcons.appendChild(b);
  return b;
}

function createWindow(title, w = 900, h = 600) {
  const win = document.createElement('div');
  win.className = 'window';
  win.style.cssText = `left:120px;top:80px;display:flex;z-index:${++z};width:${w}px;height:${h}px;`;
  win.innerHTML = `
    <div class='titlebar'>
      <span style="font-size:13px;">${title}</span>
      <div class='controls'>
        <span onclick='minWin(this)' style="opacity:.7">-</span>
        <span class='win-fs' onclick='toggleFullscreen(this)' style="opacity:.7" title="Fullscreen">\u26F6</span>
        <span onclick='closeW(this)' style="opacity:.7">\u2716</span>
      </div>
    </div>
    <div class='resizeHandle'></div>
  `;
  document.body.appendChild(win);
  drag(win);
  resize(win);
  windows.push(win);
  const fs = win.querySelector('.win-fs');
  if (fs) setMaxButtonTitle(win, fs);
  return win;
}

function setMaxButtonTitle(win, el) {
  if (!el) return;
  el.title = win.dataset.gameUrl ? 'Open game in new tab (about:blank)' : 'Fullscreen';
}

function toggleFullscreen(el) {
  const win = el.closest('.window');
  if (!win) return;
  if (win.dataset.gameUrl) {
    const u = win.dataset.gameUrl;
    const t = window.open('about:blank', '_blank');
    if (t) {
      t.document.open();
      t.document.write(
        '<!DOCTYPE html><html><head><title>Game</title>' +
        '<style>*{margin:0;padding:0;box-sizing:border-box}html,body{width:100%;height:100%;overflow:hidden;background:#000}' +
        'iframe{width:100%;height:100%;border:none;display:block}</style></head>' +
        '<body><iframe src="' + u.replace(/"/g, '&quot;') + '" allowfullscreen></iframe></body></html>'
      );
      t.document.close();
    } else {
      alert('Pop-up blocked: allow pop-ups for this site to open the game in about:blank.');
    }
    return;
  }
  if (win.classList.contains('fullscreen')) {
    win.classList.remove('fullscreen');
    if (win._fsBackup) {
      win.style.left = win._fsBackup.left;
      win.style.top = win._fsBackup.top;
      win.style.width = win._fsBackup.width;
      win.style.height = win._fsBackup.height;
    }
    el.textContent = '\u26F6';
    setMaxButtonTitle(win, el);
  } else {
    win._fsBackup = {
      left: win.style.left || '',
      top: win.style.top || '',
      width: win.style.width || '',
      height: win.style.height || ''
    };
    win.classList.add('fullscreen');
    el.textContent = '\u2750';
    el.title = 'Restore down';
  }
  bring(win);
}

function finish(win, icon, p) {
  win.task = createTask(win, icon);
  if (p) p.win = win;
}

function closeW(e) {
  const win = e.closest('.window');
  windows = windows.filter(x => x !== win);
  processes = processes.filter(p => p.win !== win);
  if (win.task) win.task.remove();
  if (win._tmCleanup) win._tmCleanup();
  win.remove();
}

function minWin(e) {
  const win = e.closest('.window');
  win.style.display = 'none';
  if (win.task) win.task.classList.remove('open');
}

/* APPS */
function openGame(url) {
  const win = createWindow('Game');
  win.dataset.gameUrl = url;
  const fs = win.querySelector('.win-fs');
  if (fs) {
    fs.textContent = '\u2197';
    setMaxButtonTitle(win, fs);
  }
  const p = allocProc({
    name: 'Game',
    mem: +(100 + Math.random() * 80).toFixed(0),
    cpu: +(Math.random() * 40).toFixed(1)
  });
  processes.push(p);
  const ifr = document.createElement('iframe');
  ifr.src = url;
  ifr.style.flex = '1';
  ifr.style.border = 'none';
  ifr.style.background = '#000';
  win.appendChild(ifr);
  finish(win, '\uD83C\uDFAE', p);
}

function openSettings() {
  const win = createWindow('Settings', 720, 520);

  const BG_PRESETS = [
    { label:'Default (Gray)', value:'#888', isDefault:true },
    { label:'Night', value:'radial-gradient(circle at center,#182033,#05070f)' },
    { label:'Sunset', value:'linear-gradient(135deg,#1a0533,#8b1a4a,#ff6b35)' },
    { label:'Forest', value:'linear-gradient(135deg,#0a2a0a,#1a5c1a,#2d8b2d)' },
    { label:'Ocean', value:'linear-gradient(135deg,#020c1b,#0d3460,#16697a)' },
    { label:'Aurora', value:'linear-gradient(135deg,#0a0a2e,#1a1a4e,#16213e,#0f3460)' },
    { label:'Rose', value:'linear-gradient(135deg,#1a0a0a,#4a0a1a,#8b2a4a)' },
    { label:'Void', value:'#000' },
  ];

  const ACCENT_PRESETS = [
    { label:'Cyan',   value:'#00d4ff' },
    { label:'Green',  value:'#00ff7f' },
    { label:'Purple', value:'#a855f7' },
    { label:'Orange', value:'#f59e0b' },
    { label:'Pink',   value:'#ec4899' },
    { label:'Red',    value:'#ef4444' },
    { label:'White',  value:'#e2e8f0' },
  ];

  const root = document.createElement('div');
  root.className = 'settings-root';

  // --- BG section ---
  const currentBg = document.body.style.background || '#888';
  let selectedBg = currentBg;

  function applyBackground(val) {
    let sheet = document.getElementById('__bgOverride');
    if (!sheet) {
      sheet = document.createElement('style');
      sheet.id = '__bgOverride';
      document.head.appendChild(sheet);
    }
    sheet.textContent = 'body { background: ' + val + ' !important; }';
    const isDefault = val === '#888';
    const demoEl = document.getElementById('desktopDemo');
    const wmEl = document.getElementById('demoWatermark');
    if (isDefault) {
      if (demoEl) demoEl.style.display = 'flex';
      if (wmEl) wmEl.style.display = '';
    } else {
      if (demoEl) demoEl.style.display = 'none';
      if (wmEl) wmEl.style.display = 'none';
    }
  }

  const bgPresetGrid = BG_PRESETS.map((p,i) => {
    const div = document.createElement('div');
    div.className = 'bg-preset' + (currentBg === p.value || (p.isDefault && !document.body.style.background) ? ' selected' : '');
    div.title = p.label;
    div.style.background = p.value;
    div.onclick = () => {
      root.querySelectorAll('.bg-preset').forEach(x => x.classList.remove('selected'));
      div.classList.add('selected');
      selectedBg = p.value;
      applyBackground(p.value);
    };
    return div;
  });

  const customInput = document.createElement('input');
  customInput.className = 'custom-bg-input';
  customInput.placeholder = 'CSS value, e.g. #ff0000 or url(...)';
  customInput.type = 'text';

  const applyBtn = document.createElement('button');
  applyBtn.className = 'settings-apply-btn';
  applyBtn.textContent = 'Apply';
  applyBtn.onclick = () => {
    const val = customInput.value.trim() || selectedBg;
    applyBackground(val);
  };

  const bgRow = document.createElement('div');
  bgRow.className = 'settings-row';
  bgPresetGrid.forEach(el => bgRow.appendChild(el));

  const customRow = document.createElement('div');
  customRow.className = 'custom-bg-row';
  customRow.appendChild(customInput);
  customRow.appendChild(applyBtn);

  const bgSection = document.createElement('div');
  bgSection.className = 'settings-section';
  bgSection.innerHTML = '<div class="settings-label">Background</div>';
  bgSection.appendChild(bgRow);
  bgSection.appendChild(customRow);

  // --- Accent section ---
  const accentSection = document.createElement('div');
  accentSection.className = 'settings-section';
  accentSection.innerHTML = '<div class="settings-label">Accent Color</div>';

  const accentRow = document.createElement('div');
  accentRow.className = 'settings-row';

  const currentAccent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#00ff7f';

  ACCENT_PRESETS.forEach(p => {
    const swatch = document.createElement('div');
    swatch.className = 'accent-swatch' + (currentAccent === p.value ? ' selected' : '');
    swatch.title = p.label;
    swatch.style.background = p.value;
