        '&nbsp;&nbsp;Default Gateway . . . . . . . . . : 192.168.1.1';
    } else if (cmd === 'ping' && args[0]) {
      const host = args[0];
      o =
        'Pinging ' +
        host +
        ' with 32 bytes of data:<br>' +
        'Reply from ' +
        host +
        ': bytes=32 time=1ms TTL=128<br>' +
        'Reply from ' +
        host +
        ': bytes=32 time=2ms TTL=128<br>' +
        'Reply from ' +
        host +
        ': bytes=32 time=1ms TTL=128<br>' +
        'Reply from ' +
        host +
        ': bytes=32 time=2ms TTL=128<br><br>' +
        'Packets: Sent = 4, Received = 4, Lost = 0 (0% loss).';
    } else if (cmd === 'ping') {
      o = 'Please give a host name. Example: ping example.com';
    } else if (cmd === 'systeminfo') {
      o =
        'Host Name:                 ' +
        (location.hostname || 'DESKTOP-WEB') +
        '<br>OS Name:                   Microsoft Windows 11 Pro<br>OS Version:                10.0.22631 N/A Build 22631<br>System Type:               ' +
        (navigator.platform || 'x64-based PC') +
        '<br>Total Physical Memory:     ' +
        (navigator.deviceMemory ? navigator.deviceMemory + ' GB' : 'Not reported') +
        '<br>Processor(s):              ' +
        (navigator.hardwareConcurrency || '?') +
        ' logical processor(s)';
    } else if (cmd === 'color') {
      o = 'The color command is not available in this simulator.';
    } else if (cmd === 'exit') {
      closeW(win.querySelector('.controls span:last-child'));
      return;
    } else {
      o = '"' + cmd + '" is not recognized as an internal or external command.<br>Type help for a list of commands.';
    }

    appendOut(raw, o);
    input.value = '';
    input.placeholder = cwd + '> ';
  };

  win.appendChild(body);
  win.appendChild(input);
  finish(win, '\u2328\uFE0F');
  setTimeout(() => input.focus(), 50);
}

