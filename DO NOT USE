    accentRow.querySelectorAll('.accent-swatch').forEach(x => x.classList.remove('selected'));
    document.documentElement.style.setProperty('--accent', accentPicker.value);
  };
  accentRow.appendChild(accentPicker);
  accentSection.appendChild(accentRow);

  root.appendChild(bgSection);
  const hr = document.createElement('hr');
  hr.className = 'settings-divider';
  root.appendChild(hr);
  root.appendChild(accentSection);

  win.appendChild(root);
  finish(win, '⚙️');
}

function openCMD() {
  const win = createWindow('CMD');
  const body = document.createElement('div');
  body.className = 'cmdBody';
  let cwd = 'C:\\Users\\User';
  body.innerHTML =
    'Command Prompt — type <b>help</b> for a list of commands.<br>' +
    'Tip: every command is one word, then any extra text (e.g. <b>echo hello</b>, <b>cd C:\\\\Temp</b>).<br><br>';

  const input = document.createElement('input');
  input.className = 'cmdInput';
  input.autocomplete = 'off';
  input.placeholder = cwd + '> ';

  function appendOut(rawCmd, outHtml) {
    const esc = String(rawCmd).replace(/</g, '&lt;');
    const rich = String(outHtml).trim().startsWith('<');
    body.innerHTML += rich
      ? 'C:\\&gt; ' + esc + '<br>' + outHtml + '<br><br>'
      : 'C:\\&gt; ' + esc + '<br><span style="opacity:.85">' + outHtml + '</span><br><br>';
    body.scrollTop = body.scrollHeight;
  }

  input.onkeydown = (e) => {
    if (e.key !== 'Enter') return;
    const raw = input.value;
    const line = raw.trim();
    const parts = line.match(/(?:[^\s"]+|"[^"]*")+/g) || [];
    const cmd = (parts[0] || '').replace(/^"(.*)"$/, '$1').toLowerCase();
    const args = parts.slice(1).map(a => a.replace(/^"(.*)"$/, '$1'));

    let o = '';
    if (!line) {
      input.value = '';
      return;
    }
    if (cmd === 'help') {
      o =
        '<div style="line-height:1.55;opacity:.95">' +
        '<b>Basics</b><br>' +
        '<code>cls</code> — clear the screen<br>' +
        '<code>exit</code> — close this window<br>' +
        '<code>ver</code> — Windows version line<br>' +
        '<code>time</code> / <code>date</code> — current time / full date<br><br>' +
        '<b>Folders</b><br>' +
        '<code>cd folder</code> — change folder (example: cd C:\\\\Temp)<br>' +
        '<code>cd</code> or <code>pwd</code> — show current folder<br>' +
        '<code>dir</code> — list files in the current folder<br><br>' +
        '<b>System info</b><br>' +
        '<code>systeminfo</code> — short summary<br>' +
        '<code>sysinfo</code> — screen size and CPU cores<br>' +
        '<code>mem</code> — memory used by this tab (when the browser allows it)<br>' +
        '<code>cpu</code> — number of logical processors<br>' +
        '<code>hostname</code> — site name from the address bar<br>' +
        '<code>whoami</code> — current user name<br><br>' +
        '<b>Network</b><br>' +
        '<code>ipconfig</code> — sample network settings<br>' +
        '<code>ping google.com</code> — sample ping (replace with any host)<br><br>' +
        '<b>Other</b><br>' +
        '<code>echo hello</code> — print text<br>' +
        '<code>title My title</code> — change the title bar text<br>' +
        '<code>color</code> — not supported here<br>' +
        '</div>';
    } else if (cmd === 'cls' || cmd === 'clear') {
      body.innerHTML = '';
      input.value = '';
      return;
    } else if (cmd === 'ver') {
      o =
        'Microsoft Windows [Version 10.0.22631.3007]<br>' +
        '<span style="opacity:.75">(This line mimics Windows; the next line is your real browser.)</span><br>' +
        navigator.userAgent;
    } else if (cmd === 'time') {
      o = 'The current time is: ' + new Date().toLocaleTimeString();
    } else if (cmd === 'date') {
      o = 'The current date and time is:<br>' + new Date().toLocaleString();
    } else if (cmd === 'hostname') {
      o =
        location.hostname
          ? 'Computer name (from the page address): ' + location.hostname
          : 'You opened this file without a web address, so there is no host name.';
    } else if (cmd === 'whoami') {
      o = 'You are logged in as: simulator\\' + (localStorage.getItem('sim_user') || 'User');
    } else if (cmd === 'cd' && args[0]) {
      cwd = args[0].replace(/\//g, '\\');
      o = 'Current folder is now:<br>' + cwd;
    } else if (cmd === 'cd' || cmd === 'pwd') {
      o = 'Current folder:<br>' + cwd;
    } else if (cmd === 'dir' || cmd === 'ls') {
      o =
        ' Volume in drive C has no label.<br> Directory of ' +
        cwd +
        '<br><br>' +
        'notes.txt&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;games<br>readme.md<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;3 File(s)';
    } else if (cmd === 'echo') {
      o = args.length ? args.join(' ') : 'ECHO is on.';
    } else if (cmd === 'title' && args.length) {
      const tEl = win.querySelector('.titlebar span');
      if (tEl) tEl.textContent = args.join(' ');
      o = 'Title changed to: ' + args.join(' ');
    } else if (cmd === 'sysinfo') {
      o =
        'Screen resolution: ' +
        screen.width +
        ' × ' +
        screen.height +
        ' pixels<br>' +
        'Logical processors: ' +
        (navigator.hardwareConcurrency || 'unknown') +
        (navigator.deviceMemory          ? '<br>Approx. device RAM (browser hint): ' + navigator.deviceMemory + ' GB'
          : '');
    } else if (cmd === 'mem') {
      if (performance.memory) {
        const u = (performance.memory.usedJSHeapSize / 1048576).toFixed(1);
        const t = (performance.memory.totalJSHeapSize / 1048576).toFixed(1);
        const l = (performance.memory.jsHeapSizeLimit / 1048576).toFixed(0);
        o =
          'Memory for this tab right now:<br>' +
