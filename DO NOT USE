  // ---- Chart drawing utility ----
  function drawSparkline(canvas, data, color, fill, dataMax) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.offsetWidth || canvas.parentElement.offsetWidth || 170;
    const H = canvas.height;
    canvas.width = W;
    ctx.clearRect(0, 0, W, H);
    const max = dataMax != null ? dataMax : 100;
    const pts = data.slice(-30);
    ctx.beginPath();
    const denom = Math.max(pts.length - 1, 1);
    pts.forEach((v, i) => {
      const x = (i / denom) * W;
      const y = H - (v / max) * H;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    if (fill) {
      ctx.lineTo(W, H); ctx.lineTo(0, H); ctx.closePath();
      ctx.fillStyle = fill;
      ctx.fill();
    }
  }

  function drawMainChart(canvasId, data, color, fillColor, maxVal) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.parentElement.offsetWidth || 600;
    const H = 180;
    canvas.width = W; canvas.height = H;
    ctx.clearRect(0, 0, W, H);

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    [25,50,75].forEach(pct => {
      const y = H - (pct / (maxVal||100)) * H;
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.font = '10px Segoe UI';
      ctx.fillText(pct + (maxVal ? '' : '%'), 4, y - 3);
    });

    // Line
    ctx.beginPath();
    const dDenom = Math.max(data.length - 1, 1);
    data.forEach((v, i) => {
      const x = (i / dDenom) * W;
      const y = H - (v / (maxVal||100)) * H;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.stroke();

    // Fill
    ctx.lineTo(W, H); ctx.lineTo(0, H); ctx.closePath();
    ctx.fillStyle = fillColor;
    ctx.fill();
  }

  // ---- Colors ----
  const COLORS = {
    cpu:  { line: '#00d4ff', fill: 'rgba(0,212,255,0.12)', mini: 'rgba(0,212,255,0.5)', miniFill: 'rgba(0,212,255,0.2)' },
    ram:  { line: '#a855f7', fill: 'rgba(168,85,247,0.12)', mini: 'rgba(168,85,247,0.6)', miniFill: 'rgba(168,85,247,0.2)' },
    disk: { line: '#22c55e', fill: 'rgba(34,197,94,0.12)',  mini: 'rgba(34,197,94,0.5)',  miniFill: 'rgba(34,197,94,0.2)' },
    net:  { line: '#f59e0b', fill: 'rgba(245,158,11,0.12)', mini: 'rgba(245,158,11,0.5)', miniFill: 'rgba(245,158,11,0.2)' },
  };

  // ---- Uptime ----
  const startTime = Date.now();

  // ---- Main update loop ----
  let loopId;
  function update() {
    step();

    const cpu = cpuVal;
    const disk = diskVal;
    const net  = netVal;
    let ramPct = ramPctLive;
    if (performance.memory) {
      ramPct = (performance.memory.usedJSHeapSize / performance.memory.jsHeapSizeLimit) * 100;
    }

    const totalRamGb = (snap && snap.dm != null) ? snap.dm : 16;
    const usedRamGb = Math.min(totalRamGb, (totalRamGb * ramPct) / 100);
    const availRamGb = Math.max(0, totalRamGb - usedRamGb);

    setText('sb-cpu',  cpu.toFixed(1)+'%');
    setText('sb-ram',  usedRamGb.toFixed(1) + ' / ' + totalRamGb.toFixed(1) + ' GB');
    setText('sb-disk', disk.toFixed(0)+'%');
    setText('sb-net',  net.toFixed(1) + ' Mbps');

    const netSparkMax = Math.max(10, ...netHistory, 1);
    drawSparkline(document.getElementById('mini-cpu'),  cpuHistory,  COLORS.cpu.mini,  COLORS.cpu.miniFill);
    drawSparkline(document.getElementById('mini-ram'),  ramHistory,  COLORS.ram.mini,  COLORS.ram.miniFill);
    drawSparkline(document.getElementById('mini-disk'), diskHistory, COLORS.disk.mini, COLORS.disk.miniFill);
    drawSparkline(document.getElementById('mini-net'),  netHistory,  COLORS.net.mini,  COLORS.net.miniFill, netSparkMax);

    drawMainChart('main-chart', cpuHistory, COLORS.cpu.line, COLORS.cpu.fill, 100);
    drawMainChart('ram-chart',  ramHistory, COLORS.ram.line, COLORS.ram.fill, 100);
    drawMainChart('disk-chart', diskHistory, COLORS.disk.line, COLORS.disk.fill, 100);
    drawMainChart('net-chart',  netHistory, COLORS.net.line, COLORS.net.fill, netSparkMax);

    const cpuPeak = Math.max(...cpuHistory);
    setText('stat-cpu-util', cpu.toFixed(1)+'%');
    setText('stat-cpu-speed', (3.1 + cpu / 200).toFixed(2) + ' GHz');
    setText('stat-proc-count', (processes.length + 42).toString());
    setText('cpu-peak-label', 'Peak: '+cpuPeak.toFixed(1)+'%');

    const secs = Math.floor((Date.now()-startTime)/1000);
    const h=Math.floor(secs/3600), m=Math.floor((secs%3600)/60), s=secs%60;
    setText('stat-uptime', `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`);

    setText('stat-ram-used', usedRamGb.toFixed(1) + ' GB');
    setText('stat-ram-avail', availRamGb.toFixed(1) + ' GB');
    setText('ram-peak-label', 'Peak: '+Math.max(...ramHistory).toFixed(1)+'%');
    setText('stat-ram-total', (usedRamGb + 2.1).toFixed(1) + ' GB');

    setText('stat-disk-val', disk.toFixed(0)+'%');
    setText('stat-disk-r', (8 + disk * 0.42).toFixed(1) + ' MB/s');
    setText('stat-disk-w', (2 + disk * 0.28).toFixed(1) + ' MB/s');
    setText('stat-disk-cap', '512 GB');

    setText('stat-net-s', (net * 0.22).toFixed(1) + ' Mbps');
    setText('stat-net-r', (net * 0.78).toFixed(1) + ' Mbps');
    setText('stat-net-ip', '192.168.1.105');
    if (snap && snap.conn && snap.conn.downlink != null) {
      const lk = Math.max(100, Math.round(snap.conn.downlink * 100));
      setText('stat-net-link', lk + '/' + lk + ' Mbps');
    } else {
      setText('stat-net-link', '1000/1000 Mbps');
    }

    const tbody = document.getElementById('proc-tbody');
    if (tbody) {
      const fakeProcs = [
        { name:'System', icon:'\uD83D\uDDA5', cpu: +(cpuVal*0.05).toFixed(1), mem:+(12+Math.random()*2).toFixed(0) },
        { name:'Explorer.exe', icon:'\uD83D\uDCC1', cpu: +(cpuVal*0.02).toFixed(1), mem:+(55+Math.random()*5).toFixed(0) },
        { name:'Dwm.exe', icon:'\uD83E\uDE9F', cpu: +(cpuVal*0.03).toFixed(1), mem:+(80+Math.random()*5).toFixed(0) },
        { name:'Antimalware', icon:'\uD83D\uDEE1', cpu: +(cpuVal*0.04).toFixed(1), mem:+(120+Math.random()*10).toFixed(0) },
        { name:'svchost.exe', icon:'\u2699', cpu: +(cpuVal*0.06).toFixed(1), mem:+(45+Math.random()*4).toFixed(0) },
        { name:'RuntimeBroker', icon:'\uD83D\uDD11', cpu: +(cpuVal*0.01).toFixed(1), mem:+(30+Math.random()*3).toFixed(0) },
        ...processes.map(p => ({ name:p.name, icon:'\uD83C\uDFAE', cpu:+p.cpu.toFixed(1), mem:+p.mem.toFixed(0), killId: p.id }))
      ];
      tbody.innerHTML = fakeProcs.map(p => `
        <tr>
          <td><div class="proc-name"><span class="proc-icon">${p.icon}</span>${p.name}</div></td>
          <td>
            <div style="font-size:12px;margin-bottom:3px;">${p.cpu}%</div>
            <div class="mini-bar"><div class="mini-bar-fill" style="width:${Math.min(p.cpu,100)}%;background:${COLORS.cpu.line};"></div></div>
          </td>
          <td>
            <div style="font-size:12px;margin-bottom:3px;">${p.mem} MB</div>
            <div class="mini-bar"><div class="mini-bar-fill" style="width:${Math.min(p.mem/8,100)}%;background:${COLORS.ram.mini};"></div></div>
          </td>
          <td style="color:#22c55e;font-size:11px;">Running</td>
          <td>${p.killId !== undefined ? `<button type="button" class="kill-btn" data-kill="${p.killId}">End</button>` : ''}</td>
        </tr>
      `).join('');
      tbody.querySelectorAll('[data-kill]').forEach(btn => {
        btn.addEventListener('click', () => killById(+btn.dataset.kill));
      });
    }

    loopId = setTimeout(update, 800);
  }

  function setText(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  update();
  win._tmCleanup = () => clearTimeout(loopId);
}

function killById(id) {
  const i = processes.findIndex(p => p.id === id);
  if (i < 0) return;
  const p = processes[i];
  if (p.win) {
    if (p.win.task) p.win.task.remove();
    if (p.win._tmCleanup) p.win._tmCleanup();
    const wi = windows.indexOf(p.win);
    if (wi >= 0) windows.splice(wi, 1);
    p.win.remove();
  }
  processes.splice(i, 1);
}

/* DRAG */
function drag(w) {
  let dx=0, dy=0, d=false;
  w.addEventListener('mousedown', e => {
    if (w.classList.contains('fullscreen')) return;
    if (e.target.tagName === 'IFRAME' || e.target.closest('.controls')) return;
    if (!e.target.closest('.titlebar')) return;
    d=true; dx=e.clientX-w.offsetLeft; dy=e.clientY-w.offsetTop; bring(w);
  });
  document.addEventListener('mousemove', e => { if(!d)return; w.style.left=(e.clientX-dx)+'px'; w.style.top=(e.clientY-dy)+'px'; });
  document.addEventListener('mouseup', ()=>d=false);
}

/* RESIZE */
function resize(w) {
  const r = w.querySelector('.resizeHandle');
  r.onmousedown = (e) => {
    if (w.classList.contains('fullscreen')) return;
    e.stopPropagation();
    document.onmousemove = ev => { w.style.width=(ev.clientX-w.offsetLeft)+'px'; w.style.height=(ev.clientY-w.offsetTop)+'px'; };
    document.onmouseup = () => { document.onmousemove=null; document.onmouseup=null; };
  };
}

/* CONTEXT MENU */
document.addEventListener('contextmenu', e => {
  e.preventDefault();
  const m = document.getElementById('menu');
  m.style.display='block'; m.style.left=e.clientX+'px'; m.style.top=e.clientY+'px';
});
document.addEventListener('click', e => {
  document.getElementById('menu').style.display='none';
  if (!e.target.closest('#start') && !e.target.closest('.taskBtn')) start.classList.remove('active');
});
</script>
</body>
